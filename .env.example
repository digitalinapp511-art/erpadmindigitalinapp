# -----------------------------------------------------------------------------
# MongoDB — connection must be defined here (no hardcoded URLs in code).
# Provide ONE of:
#   A) MONGO_URI_MAIN=...          (recommended single base URI for login + company DBs)
#   B) MONGO_URI=... or MONGODB_URI=...
#   C) MONGO_HOST=... and MONGO_PORT=...
# -----------------------------------------------------------------------------
# MONGO_URI_MAIN=mongodb://localhost:27012
# MONGO_URI=mongodb://user:pass@host:27017
MONGO_HOST=localhost
MONGO_PORT=27018

# DB + collection names (logical names on that server)
MONGO_LOGIN_DB_NAME=main_db
MONGO_USERS_COLLECTION=employee_details

# -----------------------------------------------------------------------------
# HTTP — ports always required. For production use HTTPS URLs (no LAN IP needed).
# -----------------------------------------------------------------------------
BACKEND_PORT=5008
FRONTEND_PORT=3005

# Production / public URLs (set on the server — domain + API path)
# BACKEND_BASE_URL=https://api.example.com
# FRONTEND_BASE_URL=https://app.example.com
# BACKEND_API_URL=https://api.example.com/api

# CORS: browser origins allowed to call the API (comma-separated). Recommended in production.
# CORS_ORIGIN=https://app.example.com,https://www.app.example.com
# If NODE_ENV=production and you omit CORS_ORIGIN but set FRONTEND_BASE_URL, only that origin is allowed.

# Optional: same-machine or phone-on-WiFi testing only (omit when using BACKEND_BASE_URL)
# SERVER_IP=192.168.1.10

# Single source of truth (recommended)
# MONGO_URI=mongodb://user:pass@localhost:27012
# JWT_SECRET=your-secret

# Optional: Redis response cache (falls back to in-memory if unset or unavailable)
# REDIS_URL=redis://127.0.0.1:6379
# DISABLE_RESPONSE_CACHE=true
# ATTENDANCE_STATS_CACHE_TTL_MS=60000
# ATTENDANCE_CACHE_TTL_MS=120000
# PAYROLL_CACHE_TTL_MS=300000
# DEPT_TEAM_CACHE_TTL_MS=60000

# Optional: dedicated AES key material for encrypting annual CTC in MongoDB (at rest).
# If unset, the same value as JWT_SECRET is used (set a long random string in production).
# CTC_ENCRYPTION_KEY=change-me-to-a-long-random-secret
